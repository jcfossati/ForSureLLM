# Ne remplis QUE les clés des providers que tu utilises dans llm_config.yaml.

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT-4o, o1, o3)
# OPENAI_API_KEY=sk-...

# Google Gemini
# GEMINI_API_KEY=...

# Mistral
# MISTRAL_API_KEY=...

# Groq (Llama, Mixtral hosted)
# GROQ_API_KEY=...

# OpenRouter (accès unifié à ~200 modèles)
# OPENROUTER_API_KEY=...

# Azure OpenAI
# AZURE_API_KEY=...
# AZURE_API_BASE=https://...
# AZURE_API_VERSION=2024-02-01
